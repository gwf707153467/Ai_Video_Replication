APP_NAME=ai_videos_replication
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
API_V1_PREFIX=api_v1

POSTGRES_DB=ai_videos_replication
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/ai_videos_replication

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# Runtime/object-store baseline buckets used by the current image/video-first flow.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_REFERENCE=reference-assets
MINIO_BUCKET_GENERATED_IMAGES=generated-images
MINIO_BUCKET_GENERATED_VIDEOS=generated-videos
MINIO_BUCKET_RUNTIME=runtime-packets
# Optional compatibility buckets only. Audio/export are not required by the current Relay baseline gate.
MINIO_BUCKET_AUDIO=audio-assets
MINIO_BUCKET_EXPORTS=exports

# GOOGLE_* names are kept for compatibility; values are consumed by the Relay-backed provider client.
# Current required smoke/baseline path is image + video only.
GOOGLE_API_KEY=replace_with_real_relay_key
GOOGLE_VIDEO_MODEL=replace_with_relay_video_model
GOOGLE_IMAGE_MODEL=replace_with_relay_image_model
# Optional/legacy only: Relay baseline does not require or support TTS in the current smoke path.
GOOGLE_TTS_MODEL=

DEFAULT_TARGET_MARKET=US
DEFAULT_TARGET_LANGUAGE=en-US
# Optional legacy defaults only; voice/lip-sync are not part of the current required Relay baseline.
DEFAULT_VOICE_MODE=voiceover
DEFAULT_LIP_SYNC_POLICY=none
DEFAULT_EXPORT_ASPECT_RATIO=9x16
DEFAULT_EXPORT_CONTAINER=mp4

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
