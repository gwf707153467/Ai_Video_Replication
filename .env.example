APP_NAME=ai_videos_replication
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
API_V1_PREFIX=api_v1

POSTGRES_DB=ai_videos_replication
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/ai_videos_replication

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_REFERENCE=reference-assets
MINIO_BUCKET_GENERATED_IMAGES=generated-images
MINIO_BUCKET_GENERATED_VIDEOS=generated-videos
MINIO_BUCKET_AUDIO=audio-assets
MINIO_BUCKET_EXPORTS=exports
MINIO_BUCKET_RUNTIME=runtime-packets

GOOGLE_API_KEY=replace_with_real_key
GOOGLE_VIDEO_MODEL=replace_with_video_model
GOOGLE_IMAGE_MODEL=imagen-3.0-generate-002
GOOGLE_TTS_MODEL=replace_with_tts_model

DEFAULT_TARGET_MARKET=US
DEFAULT_TARGET_LANGUAGE=en-US
DEFAULT_VOICE_MODE=voiceover
DEFAULT_LIP_SYNC_POLICY=none
DEFAULT_EXPORT_ASPECT_RATIO=9x16
DEFAULT_EXPORT_CONTAINER=mp4

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
