APP_NAME=ai_videos_replication
APP_ENV=development
LOG_LEVEL=INFO

POSTGRES_DB=ai_videos_replication
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/ai_videos_replication

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

MINIO_BUCKET_REFERENCE=reference-assets
MINIO_BUCKET_GENERATED_IMAGES=generated-images
MINIO_BUCKET_GENERATED_VIDEOS=generated-videos
MINIO_BUCKET_AUDIO=audio-assets
MINIO_BUCKET_EXPORTS=exports
MINIO_BUCKET_RUNTIME=runtime-packets

GOOGLE_API_KEY=AIzaSyBk0lbmVRPGnqhrY1XtaQAhFlSLapGe6vU
GOOGLE_VIDEO_MODEL=veo-3.1-generate-preview
GOOGLE_IMAGE_MODEL=gemini-3.1-flash-image-preview
GOOGLE_TTS_MODEL=gemini-2.5-pro-preview-tts

DEFAULT_TARGET_MARKET=US
DEFAULT_TARGET_LANGUAGE=en-US
